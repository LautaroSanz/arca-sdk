{
  "name": "arca-sdk",
  "version": "0.0.0",
  "description": "SDK TypeScript para web services de ARCA (ex-AFIP)",
  "private": true,
  "license": "UNLICENSED",
  "author": "Lautaro Sanz <lautaro.sanz@dataoilers.com>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/node-forge": "^1.3.14",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "fast-xml-parser": "^5.7.1",
    "node-forge": "^1.4.0",
    "ntp-time-sync": "^0.5.0",
    "soap": "^1.9.1"
  }
}
